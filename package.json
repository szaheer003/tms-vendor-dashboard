{
  "name": "fis-tms-vendor-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:browser": "next dev -p 3055",
    "vendor-files": "node scripts/build-vendor-files.cjs",
    "vendor-files:py": "python scripts/copy_vendor_files.py",
    "build": "next build",
    "export": "python scripts/extract_tms.py && next build",
    "start": "next start",
    "extract": "python scripts/extract_tms.py",
    "embed": "python scripts/embed_dashboard.py",
    "dashboard": "python scripts/extract_tms.py && python scripts/embed_dashboard.py",
    "serve:out": "python -m http.server 4173 --directory out",
    "preview:cursor": "python -m http.server 5510 --bind 127.0.0.1 --directory out",
    "ideal-rfp": "python scripts/build_ideal_rfp_from_docx.py",
    "import-scores": "python scripts/import_folder8_scores.py",
    "export-pdfs": "node scripts/export-dashboard-pdfs.mjs",
    "bundle:teammate": "powershell -ExecutionPolicy Bypass -File scripts/create-teammate-bundle.ps1",
    "bundle:teammate:zip-only": "powershell -ExecutionPolicy Bypass -File scripts/create-teammate-bundle.ps1 -SkipBuild",
    "refresh:data": "python scripts/extract_workshop_memos.py && python scripts/extract_tms.py && python scripts/import_folder8_scores.py",
    "refresh:dashboard": "python scripts/extract_workshop_memos.py && python scripts/extract_tms.py && python scripts/import_folder8_scores.py && python scripts/embed_dashboard.py && npm run build"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "next": "14.2.18",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^9.1.1",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "pdf-parse": "^1.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "playwright": "^1.49.1"
  }
}
